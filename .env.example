# Copy to .env for local development (loaded by your shell / process manager).
# In production these are set by the systemd unit (see ansible/).

# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Brand (shown across the site) — REPLACE with your real values
BRAND_NAME=Örgülog
BRAND_TAGLINE=İplikle, sabırla ve sevgiyle; tek tek elde örülüyor.
BRAND_INSTAGRAM=https://www.instagram.com/orgulog2/
# WhatsApp: country code + number, no + or spaces
BRAND_WHATSAPP=https://wa.me/905387277185
BRAND_EMAIL=hello@orgulog.example

# Static generator (npm run generate) — optional
# SITE_OUT=dist-site            # output folder
# BASE_PATH=/orgulog            # only for GitHub Pages project sub-paths

# Optional overrides (defaults are derived from the project root)
# VIEWS_DIR=/absolute/path/to/views
# PUBLIC_DIR=/absolute/path/to/public
