<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main>
    <section class="page-hero">
      <div class="wrap page-hero__inner reveal">
        <p class="eyebrow"><%= t.contact.eyebrow %></p>
        <h1 class="display"><%= t.contact.title %></h1>
        <p class="lede"><%= t.contact.lede %></p>
      </div>
    </section>

    <section class="section">
      <div class="wrap contact">
        <div class="contact__card reveal">
          <h2 class="h3"><%= t.contact.igTitle %></h2>
          <p><%= t.contact.igText %></p>
          <!-- #instagram-dm → Instagram profil / DM bağlantınız -->
          <a class="btn" href="<%= brand.instagramUrl %>" target="_blank" rel="noopener"><%= t.contact.igBtn %></a>
        </div>
        <div class="contact__card reveal">
          <h2 class="h3"><%= t.contact.waTitle %></h2>
          <p><%= t.contact.waText %></p>
          <!-- BRAND_WHATSAPP ile değiştirin (örn. https://wa.me/905551234567) ya da bu kartı silin -->
          <a class="btn" href="<%= brand.whatsappUrl %>" target="_blank" rel="noopener"><%= t.contact.waBtn %></a>
        </div>
        <div class="contact__card reveal">
          <h2 class="h3"><%= t.contact.emailTitle %></h2>
          <p><%= t.contact.emailText %></p>
          <!-- Adresi BRAND_EMAIL ile değiştirin ya da bu kartı tamamen silin -->
          <a class="btn btn--ghost" href="mailto:<%= brand.email %>"><%= t.contact.emailBtn %></a>
        </div>
      </div>
    </section>

    <!-- ─────────────────────── INSTAGRAM IZGARASI ───────────────── -->
    <section class="section section--tint">
      <div class="wrap">
        <div class="section__head reveal">
          <p class="eyebrow"><%= t.contact.gridEyebrow %></p>
          <h2 class="h2"><%= t.contact.gridTitle %></h2>
        </div>

        <!--
          İPUCU: CANLI bir Instagram akışı göstermek için bu ızgarayı
          LightWidget (lightwidget.com) veya Instagram'ın kendi gömme koduyla
          değiştirebilirsiniz. Aksi halde bu fotoğrafları en yeni kareleriniz
          ile değiştirin.
        -->
        <% var studio = [
             'doll-monkey.jpeg', 'bag-woven-camel.jpeg', 'doll-cow-flowers.jpeg',
             'bag-clutch-silver.jpeg', 'doll-bunny-blue.jpeg', 'bag-woven-rose.jpeg'
           ]; %>
        <div class="insta-grid reveal">
          <% studio.forEach(function (file) { %>
            <a class="insta-grid__item" href="<%= brand.instagramUrl %>" target="_blank" rel="noopener">
              <img src="/images/<%= file %>" alt="<%= t.contact.gridAlt %>" loading="lazy" />
            </a>
          <% }); %>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
