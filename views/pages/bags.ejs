<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main>
    <section class="page-hero">
      <div class="wrap page-hero__inner reveal">
        <p class="eyebrow">Çantalar</p>
        <!-- REPLACE: çantalar başlığı -->
        <h1 class="display">Her güne, her şıklığa çantalar.</h1>
        <!-- REPLACE: çantalar açıklaması -->
        <p class="lede">
          Sağlam, yumuşak ve kullanılmak için yapıldı. Her çanta doğal ipliklerden elde
          örülür ve taşıdıkça daha da güzelleşir.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <% if (products.length === 0) { %>
          <p class="empty">Yeni ürünler tezgahta — yakında tekrar göz atın.</p>
        <% } else { %>
          <div class="grid grid--3">
            <% products.forEach(function (product) { %>
              <%- include('../partials/product-card', { product: product }) %>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>

    <section class="strip">
      <div class="wrap strip__inner strip__inner--center reveal">
        <p class="script strip__cta">Kendi renklerinizde ister misiniz?</p>
        <a class="btn" href="/contact">Size özel çanta isteyin</a>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
