<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main>
    <!-- ─────────────────────────── HERO ─────────────────────────── -->
    <section class="hero">
      <div class="wrap hero__inner">
        <div class="hero__text reveal">
          <p class="eyebrow"><%= t.home.eyebrow %></p>
          <h1 class="display"><%- t.home.titleHtml %></h1>
          <p class="lede"><%= t.home.lede.replace('{brand}', brand.name) %></p>
          <div class="hero__cta">
            <a class="btn" href="<%= href('/dolls') %>"><%= t.home.ctaDolls %></a>
            <a class="btn btn--ghost" href="<%= href('/bags') %>"><%= t.home.ctaBags %></a>
          </div>
        </div>

        <div class="hero__media reveal">
          <!-- REPLACE: dilediğiniz hero fotoğrafıyla değiştirin -->
          <img src="/images/hero-monkey.jpeg" alt="<%= t.home.heroImgAlt %>" />
          <span class="hero__note script"><%= t.home.heroNote %></span>
        </div>
      </div>
    </section>

    <!-- ─────────────────────── ÖNE ÇIKANLAR ─────────────────────── -->
    <section class="section">
      <div class="wrap">
        <div class="section__head reveal">
          <p class="eyebrow"><%= t.home.featuredEyebrow %></p>
          <h2 class="h2"><%= t.home.featuredTitle %></h2>
        </div>

        <div class="grid grid--3">
          <% featured.forEach(function (product) { %>
            <%- include('../partials/product-card', { product: product }) %>
          <% }); %>
        </div>

        <div class="section__more reveal">
          <a class="link-more" href="<%= href('/dolls') %>"><%= t.home.more %></a>
        </div>
      </div>
    </section>

    <!-- ─────────────────────── FOTOĞRAF GALERİSİ ────────────────── -->
    <section class="section section--tint">
      <div class="wrap">
        <div class="section__head reveal">
          <p class="eyebrow"><%= t.home.galleryEyebrow %></p>
          <h2 class="h2"><%= t.home.galleryTitle %></h2>
        </div>

        <div class="gallery">
          <% gallery.forEach(function (product) { %>
            <a class="gallery__item reveal" href="<%= href(product.category === 'bag' ? '/bags' : '/dolls') %>" aria-label="<%= product.name %>">
              <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" />
            </a>
          <% }); %>
        </div>
      </div>
    </section>

    <!-- ─────────────────────────── ŞERİT ────────────────────────── -->
    <section class="strip">
      <div class="wrap strip__inner reveal">
        <div class="strip__item"><span class="strip__num">01</span><p><%= t.home.strip1 %></p></div>
        <div class="strip__item"><span class="strip__num">02</span><p><%= t.home.strip2 %></p></div>
        <div class="strip__item"><span class="strip__num">03</span><p><%= t.home.strip3 %></p></div>
      </div>
    </section>

    <!-- ─────────────────────── HİKAYE TANITIMI ──────────────────── -->
    <section class="section section--tint">
      <div class="wrap teaser reveal">
        <blockquote class="pull script"><%= t.home.quote %></blockquote>
        <a class="btn btn--ghost" href="<%= href('/story') %>"><%= t.home.storyCta %></a>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
