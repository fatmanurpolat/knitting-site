<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main>
    <section class="page-hero">
      <div class="wrap page-hero__inner reveal">
        <p class="eyebrow"><%= t.dolls.eyebrow %></p>
        <h1 class="display"><%= t.dolls.title %></h1>
        <p class="lede"><%= t.dolls.lede %></p>
      </div>
    </section>

    <section class="section">
      <div class="wrap">
        <% if (products.length === 0) { %>
          <p class="empty"><%= t.dolls.empty %></p>
        <% } else { %>
          <div class="grid grid--3">
            <% products.forEach(function (product) { %>
              <%- include('../partials/product-card', { product: product }) %>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>

    <section class="strip">
      <div class="wrap strip__inner strip__inner--center reveal">
        <p class="script strip__cta"><%= t.dolls.stripCta %></p>
        <a class="btn" href="<%= href('/contact') %>"><%= t.dolls.stripBtn %></a>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
