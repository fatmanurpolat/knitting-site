<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main>
    <section class="page-hero">
      <div class="wrap page-hero__inner reveal">
        <p class="eyebrow"><%= t.story.eyebrow %></p>
        <h1 class="display"><%= t.story.title %></h1>
      </div>
    </section>

    <section class="section">
      <div class="wrap story-lead">
        <div class="story-lead__portrait reveal">
          <!-- REPLACE: story-portrait -->
          <img src="/images/story-portrait.png" alt="<%= t.story.portraitAlt %>" />
          <span class="caption script"><%= t.story.caption %></span>
        </div>
        <div class="story-lead__text reveal">
          <p><%= t.story.lead1 %></p>
          <blockquote class="pull script"><%= t.story.pull1 %></blockquote>
          <p><%= t.story.lead2 %></p>
        </div>
      </div>
    </section>

    <section class="section section--tint">
      <div class="wrap">
        <div class="section__head reveal">
          <p class="eyebrow"><%= t.story.processEyebrow %></p>
          <h2 class="h2"><%= t.story.processTitle %></h2>
        </div>

        <ol class="process">
          <li class="process__step reveal">
            <div class="process__media">
              <img src="/images/story-process-1.png" alt="<%= t.story.step1Alt %>" />
            </div>
            <div class="process__text">
              <span class="process__num">1</span>
              <h3><%= t.story.step1Title %></h3>
              <p><%= t.story.step1Text %></p>
            </div>
          </li>
          <li class="process__step reveal">
            <div class="process__media">
              <img src="/images/story-process-2.png" alt="<%= t.story.step2Alt %>" />
            </div>
            <div class="process__text">
              <span class="process__num">2</span>
              <h3><%= t.story.step2Title %></h3>
              <p><%= t.story.step2Text %></p>
            </div>
          </li>
          <li class="process__step reveal">
            <div class="process__media process__media--photo">
              <img src="/images/story-process-3.jpeg" alt="<%= t.story.step3Alt %>" />
            </div>
            <div class="process__text">
              <span class="process__num">3</span>
              <h3><%= t.story.step3Title %></h3>
              <p><%= t.story.step3Text %></p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <section class="section">
      <div class="wrap teaser reveal">
        <p class="lede" style="text-align:center"><%= t.story.closingLede %></p>
        <blockquote class="pull script"><%= t.story.closingQuote %></blockquote>
        <a class="btn" href="<%= href('/contact') %>"><%= t.story.closingCta %></a>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
