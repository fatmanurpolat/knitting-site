<!DOCTYPE html>
<html lang="<%= locale %>">
<head>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/nav') %>

  <main>
    <section class="page-hero page-hero--tall">
      <div class="wrap page-hero__inner reveal">
        <p class="eyebrow"><%= t.notFound.eyebrow %></p>
        <h1 class="display"><%= t.notFound.title %></h1>
        <p class="lede"><%= t.notFound.leadPre %><code><%= requestedPath %></code><%= t.notFound.leadPost %></p>
        <div class="hero__cta">
          <a class="btn" href="<%= href('/') %>"><%= t.notFound.backHome %></a>
          <a class="btn btn--ghost" href="<%= href('/dolls') %>"><%= t.notFound.seeDolls %></a>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
