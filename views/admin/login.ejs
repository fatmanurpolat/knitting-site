<!DOCTYPE html>
<html lang="tr">
<head>
  <%- include('_head', { title: 'Giriş' }) %>
</head>
<body class="admin admin--auth">
  <main class="auth-card">
    <a class="auth-brand" href="/">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 32 32" width="26" height="26" fill="none">
          <path d="M6 20c0-6 4-10 10-10s10 4 10 10c0 3-2 5-5 5s-5-2-5-5 2-4 4-4"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </span>
      <span><%= brandName %></span>
    </a>
    <h1>Panel Girişi</h1>

    <% if (disabled) { %>
      <p class="auth-note">Panel devre dışı — sunucuda <code>ADMIN_PASSWORD</code> ayarlanmalı.</p>
    <% } %>
    <% if (error) { %>
      <p class="auth-error"><%= error %></p>
    <% } %>

    <form method="post" action="/admin/login" class="stack">
      <label>Kullanıcı adı
        <input type="text" name="user" value="admin" autocomplete="username" required />
      </label>
      <label>Şifre
        <input type="password" name="password" autocomplete="current-password" required autofocus />
      </label>
      <button class="btn" type="submit">Giriş yap</button>
    </form>
  </main>
</body>
</html>
