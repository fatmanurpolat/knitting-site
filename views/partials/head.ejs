<%
  // Per-page <title> and meta description, from the localized messages.
  // An empty meta title means "use the brand name alone" (the home page).
  const m = t.meta[activePage] || t.meta.home;
  const pageTitle = m.title ? m.title + ' · ' + brand.name : brand.name;
  const pageDesc = m.description.replace('{brand}', brand.name);
  const ogLocale = { tr: 'tr_TR', en: 'en_US', de: 'de_DE' }[locale] || 'tr_TR';
%>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title><%= pageTitle %></title>
<meta name="description" content="<%= pageDesc %>" />
<meta name="theme-color" content="#FBF5DD" />

<!-- Alternate language versions of this page (SEO). -->
<% langLinks.forEach(function (l) { %>
<link rel="alternate" hreflang="<%= l.locale %>" href="<%= l.href %>" />
<% }); %>

<!-- Open Graph (nice link previews when shared) -->
<meta property="og:type" content="website" />
<meta property="og:title" content="<%= pageTitle %>" />
<meta property="og:description" content="<%= pageDesc %>" />
<meta property="og:locale" content="<%= ogLocale %>" />

<!--
  Fonts load from Google Fonts and need an internet connection on the
  visitor's device. To self-host: download the families and update these
  links + the @font-face rules in /public/css/styles.css.
-->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Karla:wght@300;400;500;600&display=swap"
  rel="stylesheet"
/>
<link rel="stylesheet" href="/css/styles.css" />
<link rel="icon" href="/images/favicon.svg" type="image/svg+xml" />
