<header class="site-header" data-nav>
  <div class="wrap site-header__inner">
    <a class="brand" href="/">
      <span class="brand__mark" aria-hidden="true">
        <!-- little crochet-loop mark -->
        <svg viewBox="0 0 32 32" width="26" height="26" fill="none">
          <path d="M6 20c0-6 4-10 10-10s10 4 10 10c0 3-2 5-5 5s-5-2-5-5 2-4 4-4"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </span>
      <span class="brand__name"><%= brand.name %></span>
    </a>

    <button class="nav-toggle" data-nav-toggle aria-label="Menüyü aç" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav" data-nav-menu aria-label="Ana menü">
      <ul>
        <% nav.forEach(function (item) { %>
          <li>
            <a href="<%= item.href %>"
               class="site-nav__link<%= activePage === item.key ? ' is-active' : '' %>"
               <%= activePage === item.key ? 'aria-current="page"' : '' %>>
              <%= item.label %>
            </a>
          </li>
        <% }); %>
      </ul>
    </nav>
  </div>
</header>
