<%
  // Purchase flow (no on-site payment):
  //  • If a shop listing exists → primary button links out to Etsy/Amazon.
  //  • Otherwise → primary button opens a direct message to order.
  //  • Instagram + WhatsApp are always offered for questions.
  var listed = product.etsyUrl && product.etsyUrl !== '#etsy-link';
  var shopLabel = /amazon\./i.test(product.etsyUrl) ? "Amazon'dan al"
                 : /etsy\./i.test(product.etsyUrl) ? "Etsy'den al"
                 : 'Ürünü incele';
  var ig = (product.instagramUrl && product.instagramUrl !== '#instagram-dm')
             ? product.instagramUrl : brand.instagramUrl;
  var hasWhatsapp = brand.whatsappUrl && brand.whatsappUrl !== '#whatsapp';
%>
<article class="card reveal">
  <div class="card__media">
    <img src="<%= product.image %>" alt="<%= product.name %>" loading="lazy" />
  </div>
  <div class="card__body">
    <h3 class="card__name"><%= product.name %></h3>
    <p class="card__desc"><%= product.description %></p>

    <div class="card__actions">
      <% if (listed) { %>
        <a class="btn btn--sm" href="<%= product.etsyUrl %>" target="_blank" rel="noopener"><%= shopLabel %></a>
      <% } else { %>
        <a class="btn btn--sm" href="<%= hasWhatsapp ? brand.whatsappUrl : ig %>" target="_blank" rel="noopener">Sipariş için yazın</a>
      <% } %>
    </div>

    <p class="card__inquire">
      Sorular için:
      <a href="<%= ig %>" target="_blank" rel="noopener">Instagram</a><% if (hasWhatsapp) { %>
      · <a href="<%= brand.whatsappUrl %>" target="_blank" rel="noopener">WhatsApp</a><% } %>
    </p>
  </div>
</article>
